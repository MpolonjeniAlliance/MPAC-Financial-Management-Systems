<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#c62828">
  <title>MPAC Stewardship | Full Suite + Archive & Excel Export</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.0.0/dist/chartjs-plugin-datalabels.min.js"></script>
  <script src="https://cdn.sheetjs.com/xlsx-0.20.2/package/dist/xlsx.full.min.js"></script>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --church-red: #c62828;
      --church-red-dark: #b71c1c;
      --church-blue: #0a2f44;
      --church-blue-dark: #082435;
      --church-gold: #f5b042;
      --shadow-xl: 0 25px 50px -12px rgba(0,0,0,0.3);
      --shadow-glow: 0 0 20px rgba(198,40,40,0.3);
    }
    body { font-family: 'Inter', sans-serif; background: radial-gradient(circle at 10% 20%, #fff8f0 0%, #fff0e0 100%); min-height: 100vh; }
    .login-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); backdrop-filter: blur(14px); z-index: 2000; display: flex; align-items: center; justify-content: center; }
    .login-container { background: rgba(10,20,35,0.92); backdrop-filter: blur(16px); border-radius: 2rem; padding: 2.5rem; width: 90%; max-width: 480px; border: 1px solid rgba(245,176,66,0.4); text-align: center; animation: fadeInUp 0.6s; }
    @keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    .login-logo { width: 110px; height: 110px; background: linear-gradient(145deg, #f5b042, #ffd966); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.2rem; overflow: hidden; padding: 8px; }
    .login-logo img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
    .login-container h2 { font-size: 1.8rem; font-weight: 800; background: linear-gradient(135deg, #f5b042, #ffd966); -webkit-background-clip: text; background-clip: text; color: transparent; }
    .login-sub { color: #a0c4ff; font-size: 0.85rem; margin-bottom: 2rem; }
    .input-group { margin-bottom: 1.5rem; text-align: left; }
    .input-group label { display: block; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; font-weight: 600; color: #f5b042; margin-bottom: 0.5rem; }
    .login-input { width: 100%; padding: 14px 18px; background: rgba(0,0,0,0.5); border: 1px solid rgba(245,176,66,0.3); border-radius: 1rem; color: white; font-size: 1rem; }
    .login-input:focus { outline: none; border-color: #f5b042; }
    .login-btn { background: linear-gradient(135deg, #c62828, #b71c1c); width: 100%; padding: 14px; border: none; border-radius: 2rem; font-weight: 800; color: white; cursor: pointer; }
    .error-message { background: rgba(198,40,40,0.9); padding: 10px; border-radius: 40px; font-size: 0.8rem; margin-top: 1rem; display: none; }
    .dashboard-wrapper { display: none; }
    .dashboard-wrapper.visible { display: block; }
    .container { max-width: 1800px; margin: 0 auto; padding: 20px; }
    .hero { background: linear-gradient(135deg, var(--church-blue), #041e2c); border-radius: 48px; padding: 30px 40px; margin-bottom: 30px; border: 1px solid rgba(245,176,66,0.3); box-shadow: var(--shadow-xl); }
    .hero-content { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px; }
    .logo-area { display: flex; align-items: center; gap: 20px; }
    .logo-ring { width: 75px; height: 75px; background: linear-gradient(135deg, var(--church-red), var(--church-red-dark)); border-radius: 50%; display: flex; align-items: center; justify-content: center; animation: epicPulse 2.2s infinite; }
    @keyframes epicPulse { 0%, 100% { box-shadow: 0 0 0 0 rgba(198,40,40,0.6); } 50% { box-shadow: 0 0 0 15px rgba(198,40,40,0); } }
    .logo-ring img { width: 65px; height: 65px; border-radius: 50%; object-fit: cover; border: 2px solid var(--church-gold); }
    .title h1 { font-size: 1.8rem; font-weight: 900; background: linear-gradient(135deg, #fff, var(--church-gold), #ffd966); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .title p { color: rgba(255,255,255,0.8); font-size: 0.7rem; letter-spacing: 2px; }
    .balance-card { background: linear-gradient(135deg, rgba(255,255,255,0.15), rgba(198,40,40,0.2)); backdrop-filter: blur(12px); padding: 15px 30px; border-radius: 60px; text-align: center; border: 1px solid var(--church-gold); }
    .balance-card .amount { font-size: 2rem; font-weight: 800; color: white; }
    .sync-status { font-size: 0.65rem; margin-top: 5px; color: var(--church-gold); }
    .export-archive-btn { background: linear-gradient(135deg, #1e5a5a, #0f3b3b); border: none; padding: 12px 28px; border-radius: 60px; font-weight: 800; color: white; cursor: pointer; display: flex; align-items: center; gap: 12px; transition: transform 0.2s, box-shadow 0.2s; box-shadow: 0 8px 16px rgba(0,0,0,0.2); }
    .export-archive-btn:hover { transform: translateY(-2px); background: linear-gradient(135deg, #267a7a, #145252); }
    .tabs { display: flex; gap: 8px; background: white; border-radius: 80px; padding: 8px; margin-bottom: 30px; flex-wrap: wrap; box-shadow: var(--shadow-xl); }
    .tab { flex: 1; background: transparent; border: none; padding: 12px 16px; border-radius: 60px; font-weight: 800; font-size: 0.85rem; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; color: #4b5563; transition: all 0.3s; }
    .tab.active { background: linear-gradient(135deg, var(--church-red), var(--church-red-dark)); color: white; }
    .filter-bar { background: white; border-radius: 40px; padding: 20px 28px; margin-bottom: 30px; display: flex; gap: 16px; flex-wrap: wrap; align-items: flex-end; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1); }
    .filter-group { flex: 1; min-width: 130px; }
    .filter-group label { font-weight: 800; font-size: 0.7rem; margin-bottom: 8px; color: var(--church-blue); text-transform: uppercase; display: flex; align-items: center; gap: 6px; }
    .filter-group select, .filter-group input { width: 100%; padding: 10px 14px; border: 2px solid #e9ecef; border-radius: 40px; font-weight: 600; background: white; }
    .filter-group input:focus, .filter-group select:focus { border-color: var(--church-red); outline: none; }
    .date-range-group { display: flex; gap: 12px; min-width: 280px; }
    .apply-btn, .reset-btn { border: none; padding: 10px 28px; border-radius: 50px; font-weight: 800; cursor: pointer; display: flex; align-items: center; gap: 8px; }
    .apply-btn { background: linear-gradient(135deg, var(--church-red), var(--church-red-dark)); color: white; }
    .reset-btn { background: #64748b; color: white; }
    .cards-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-bottom: 30px; }
    .stat-card { background: white; border-radius: 28px; padding: 20px; text-align: center; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1); border-bottom: 3px solid var(--church-red); transition: all 0.3s; }
    .stat-card:hover { transform: translateY(-5px); }
    .stat-card .card-value { font-size: 1.8rem; font-weight: 800; color: var(--church-blue); }
    .trend-up { color: #10b981; font-weight: 700; background: rgba(16,185,129,0.1); padding: 2px 8px; border-radius: 40px; display: inline-block; }
    .trend-down { color: var(--church-red); font-weight: 700; background: rgba(198,40,40,0.1); padding: 2px 8px; border-radius: 40px; }
    .dashboard-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(500px, 1fr)); gap: 24px; margin-bottom: 30px; }
    .chart-card { background: white; border-radius: 32px; padding: 24px; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1); border: 1px solid rgba(198,40,40,0.1); }
    .chart-card h3 { font-size: 1.1rem; font-weight: 800; margin-bottom: 20px; color: var(--church-blue); border-left: 4px solid var(--church-red); padding-left: 15px; display: flex; justify-content: space-between; align-items: center; }
    .chart-container { height: 280px; position: relative; }
    .data-table { overflow-x: auto; background: white; border-radius: 28px; padding: 20px; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1); margin-top: 20px; }
    .data-table table { width: 100%; border-collapse: collapse; }
    .data-table th, .data-table td { padding: 12px; text-align: left; border-bottom: 1px solid #e2e8f0; }
    .data-table th { background: #f8fafc; font-weight: 800; color: var(--church-blue); border-top: 2px solid var(--church-red); }
    .data-table tr:hover { background: #fef5e8; }
    .amount-positive { color: #10b981; font-weight: 700; }
    .amount-negative { color: var(--church-red); font-weight: 700; }
    .badge-epic { padding: 4px 12px; border-radius: 60px; font-size: 0.7rem; font-weight: 700; background: linear-gradient(135deg, #c62828, #e05a5a); color: white; display: inline-block; }
    .badge-blue { background: linear-gradient(135deg, #0a2f44, #1e5a7a); }
    .badge-red { background: linear-gradient(135deg, #b71c1c, #d64545); }
    .portal-container { background: white; border-radius: 44px; box-shadow: var(--shadow-xl); overflow: hidden; margin-bottom: 30px; }
    .portal-header { background: linear-gradient(115deg, #1f2e3a, #0f2838); padding: 28px 36px; border-bottom: 3px solid var(--church-gold); }
    .portal-header h2 { color: white; font-size: 1.5rem; font-weight: 800; display: flex; align-items: center; gap: 12px; }
    .type-cards-epic { display: flex; gap: 28px; padding: 32px 36px; background: linear-gradient(135deg, #fefaf5, #fff6ed); flex-wrap: wrap; }
    .epic-card { flex: 1; min-width: 280px; border-radius: 32px; padding: 24px; cursor: pointer; transition: all 0.35s; box-shadow: 0 8px 20px rgba(0,0,0,0.08); }
    .epic-card.offering-card { background: linear-gradient(145deg, #fff8f5, #fff0e8); border: 2px solid rgba(198,40,40,0.3); }
    .epic-card.offering-card.active { border: 3px solid #c62828; transform: translateY(-4px); }
    .epic-card.tithes-card { background: linear-gradient(145deg, #f0f6fa, #e8f0f5); border: 2px solid rgba(10,47,68,0.3); }
    .epic-card.tithes-card.active { border: 3px solid #0a2f44; transform: translateY(-4px); }
    .epic-card.expenses-card { background: linear-gradient(145deg, #fff5f2, #ffece6); border: 2px solid rgba(183,28,28,0.3); }
    .epic-card.expenses-card.active { border: 3px solid #b71c1c; transform: translateY(-4px); }
    .card-header-epic { display: flex; align-items: center; gap: 14px; margin-bottom: 20px; padding-bottom: 15px; border-bottom: 2px solid rgba(0,0,0,0.08); }
    .card-header-epic i { font-size: 2rem; }
    .card-header-epic h3 { font-size: 1.4rem; font-weight: 800; }
    .offering-card .card-header-epic i, .offering-card .card-header-epic h3 { color: #c62828; }
    .tithes-card .card-header-epic i, .tithes-card .card-header-epic h3 { color: #0a2f44; }
    .expenses-card .card-header-epic i, .expenses-card .card-header-epic h3 { color: #b71c1c; }
    .form-container { padding: 32px 36px; background: white; }
    .form-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
    .form-label { font-weight: 800; font-size: 0.7rem; margin-bottom: 8px; color: var(--church-blue); text-transform: uppercase; }
    .form-input, .form-select { width: 100%; padding: 14px 20px; border: 2px solid #e9e2d8; border-radius: 40px; font-weight: 500; }
    .form-input:focus, .form-select:focus { border-color: var(--church-red); outline: none; }
    .submit-btn { background: linear-gradient(135deg, var(--church-red), var(--church-red-dark)); color: white; border: none; padding: 16px 28px; border-radius: 60px; font-weight: 800; width: 100%; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 12px; margin-top: 24px; transition: all 0.2s; }
    .submit-btn:disabled { opacity: 0.6; cursor: not-allowed; background: linear-gradient(135deg, #9e9e9e, #757575); }
    .hidden { display: none; }
    .burn-rate-badge { font-size: 0.8rem; padding: 4px 12px; border-radius: 20px; }
    .burn-rate-badge.good { background: rgba(16,185,129,0.15); color: #10b981; }
    .burn-rate-badge.warning { background: rgba(245,158,11,0.15); color: #f59e0b; }
    .burn-rate-badge.critical { background: rgba(198,40,40,0.15); color: #c62828; }
    .toast { position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%); background: #1e293b; color: white; padding: 12px 28px; border-radius: 60px; z-index: 2000; display: none; border-left: 5px solid var(--church-gold); font-weight: 600; }
    @media (max-width: 1000px) { .type-cards-epic { flex-direction: column; } .dashboard-grid { grid-template-columns: 1fr; } .form-grid { grid-template-columns: 1fr; } .hero-content { flex-direction: column; align-items: stretch; } .export-archive-btn { justify-content: center; } }
  </style>
</head>
<body>

<div id="loginOverlay" class="login-overlay">
  <div class="login-container">
    <div class="login-logo"><img src="https://i.imgur.com/kTumLOY.jpg" alt="MPAC Church Logo" onerror="this.src='https://via.placeholder.com/100?text=MPAC'"></div>
    <h2>MPAC Financial System</h2>
    <div class="login-sub">Google Sheets Sync • Individual Records • Full Archive Export</div>
    <form id="loginForm">
      <div class="input-group"><label><i class="fas fa-user-lock"></i> Username</label><input type="text" id="loginUsername" class="login-input" placeholder="Enter username"></div>
      <div class="input-group"><label><i class="fas fa-key"></i> Password</label><input type="password" id="loginPassword" class="login-input" placeholder="Enter password"></div>
      <button type="submit" class="login-btn"><i class="fas fa-sign-in-alt"></i> Access Dashboard</button>
      <div id="loginError" class="error-message"><i class="fas fa-exclamation-triangle"></i> Invalid credentials</div>
    </form>
  </div>
</div>

<div id="dashboardWrapper" class="dashboard-wrapper">
  <div class="container">
    <div class="hero">
      <div class="hero-content">
        <div class="logo-area">
          <div class="logo-ring"><img src="https://i.imgur.com/kTumLOY.jpg" alt="MPAC Church Logo"></div>
          <div class="title"><h1>MPAC FINANCIAL SYSTEM</h1><p>GOOGLE SHEETS • INDIVIDUAL OFFERINGS • TITHES • EXPENSES</p></div>
        </div>
        <div class="balance-card">
          <div class="amount" id="balanceAmount">ZAR 0</div>
          <div class="sync-status" id="syncStatus">🟢 Connecting to Google Sheets...</div>
        </div>
        <button id="exportMasterArchiveBtn" class="export-archive-btn"><i class="fas fa-file-excel fa-lg"></i> 📀 Archive All Data → Excel</button>
      </div>
    </div>

    <div class="tabs">
      <button class="tab active" data-tab="dataentry"><i class="fas fa-pen-alt"></i> Data Entry</button>
      <button class="tab" data-tab="overview"><i class="fas fa-chart-pie"></i> Overview</button>
      <button class="tab" data-tab="offerings"><i class="fas fa-hand-holding-heart"></i> Offerings</button>
      <button class="tab" data-tab="tithes"><i class="fas fa-church"></i> Tithes</button>
      <button class="tab" data-tab="expenses"><i class="fas fa-receipt"></i> Expenses</button>
      <button class="tab" data-tab="advanced"><i class="fas fa-chart-line"></i> Advanced</button>
    </div>

    <div id="filterBar" class="filter-bar">
      <div class="filter-group"><label><i class="fas fa-calendar-year"></i> Year</label><select id="yearFilter"><option value="all">All Years</option><option value="2026">2026</option><option value="2025">2025</option></select></div>
      <div class="filter-group"><label><i class="fas fa-calendar-month"></i> Month</label><select id="monthFilter"><option value="all">All Months</option><option value="1">Jan</option><option value="2">Feb</option><option value="3">Mar</option><option value="4">Apr</option><option value="5">May</option><option value="6">Jun</option><option value="7">Jul</option><option value="8">Aug</option><option value="9">Sep</option><option value="10">Oct</option><option value="11">Nov</option><option value="12">Dec</option></select></div>
      <div class="filter-group"><label><i class="fas fa-tag"></i> Category</label><select id="categoryFilter"><option value="all">All Categories</option><option value="offerings">Offerings Only</option><option value="tithes">Tithes Only</option><option value="expenses">Expenses Only</option></select></div>
      <div class="date-range-group"><div class="filter-group"><label><i class="fas fa-calendar-alt"></i> From Date</label><input type="date" id="startDateFilter"></div><div class="filter-group"><label><i class="fas fa-calendar-alt"></i> To Date</label><input type="date" id="endDateFilter"></div></div>
      <button id="applyFilters" class="apply-btn"><i class="fas fa-filter"></i> Apply</button>
      <button id="resetFilters" class="reset-btn"><i class="fas fa-undo-alt"></i> Reset</button>
    </div>

    <!-- Data Entry Tab (identical to original full layout) -->
    <div id="dataentryTab" class="tab-pane active">
      <div class="portal-container">
        <div class="portal-header"><h2><i class="fas fa-cloud-upload-alt"></i> Individual Financial Entry • Google Sheets Sync</h2></div>
        <div class="type-cards-epic">
          <div class="epic-card offering-card active" data-type="offering"><div class="card-header-epic"><i class="fas fa-hand-holding-heart"></i><h3>Offerings</h3></div><div class="badges-grid-epic"><span class="badge-epic">General</span><span class="badge-epic">Thanksgiving</span><span class="badge-epic">Building</span><span class="badge-epic">Mission</span><span class="badge-epic">First Fruits</span></div></div>
          <div class="epic-card tithes-card" data-type="tithe"><div class="card-header-epic"><i class="fas fa-church"></i><h3>Tithes</h3></div><div class="badges-grid-epic"><span class="badge-epic badge-blue">Regular (10%)</span><span class="badge-epic badge-blue">First Tithe</span></div></div>
          <div class="epic-card expenses-card" data-type="expense"><div class="card-header-epic"><i class="fas fa-receipt"></i><h3>Expenses</h3></div><div class="badges-grid-epic"><span class="badge-epic badge-red">Utilities</span><span class="badge-epic badge-red">Salaries</span><span class="badge-epic badge-red">Maintenance</span></div></div>
        </div>
        <div id="offeringFormContainer" class="form-container"><form id="offeringForm"><div class="form-grid"><div><label class="form-label">Date</label><input type="date" id="offeringDate" class="form-input"></div><div><label class="form-label">Offering Type</label><select id="offeringTypeSelect" class="form-select"><option>General Offering</option><option>Thanksgiving</option><option>Building Fund</option><option>Mission Fund</option><option>First Fruits</option><option>Seed Offering</option><option>Special Offering</option><option>Social Welfare</option></select></div><div><label class="form-label">Amount (ZAR)</label><input type="number" id="offeringAmount" class="form-input" step="0.01"></div><div><label class="form-label">Individual / Received By</label><input type="text" id="offeringReceivedBy" class="form-input" placeholder="Giver or treasurer name"></div></div><button type="submit" id="saveOfferingBtn" class="submit-btn"><i class="fas fa-save"></i> Save to Google Sheets</button></form></div>
        <div id="titheFormContainer" class="form-container hidden"><form id="titheForm"><div class="form-grid"><div><label class="form-label">Date</label><input type="date" id="titheDate" class="form-input"></div><div><label class="form-label">Member Name (Individual)</label><input type="text" id="memberName" class="form-input" placeholder="Full name of tither"></div><div><label class="form-label">Tithe Type</label><select id="titheTypeSelect" class="form-select"><option>Regular Tithe (10%)</option><option>First Tithe</option><option>Special Tithe</option></select></div><div><label class="form-label">Amount (ZAR)</label><input type="number" id="titheAmount" class="form-input" step="0.01"></div></div><button type="submit" id="saveTitheBtn" class="submit-btn"><i class="fas fa-save"></i> Save to Google Sheets</button></form></div>
        <div id="expenseFormContainer" class="form-container hidden"><form id="expenseForm"><div class="form-grid"><div><label class="form-label">Date</label><input type="date" id="expenseDate" class="form-input"></div><div><label class="form-label">Category</label><select id="expenseCategorySelect" class="form-select"><option>Utilities</option><option>Salaries</option><option>Maintenance</option><option>Programs</option><option>Outreach</option><option>Social Welfare</option></select></div><div><label class="form-label">Description / Vendor</label><input type="text" id="expenseDescription" class="form-input" placeholder="Individual vendor or purpose"></div><div><label class="form-label">Amount (ZAR)</label><input type="number" id="expenseAmount" class="form-input" step="0.01"></div></div><button type="submit" id="saveExpenseBtn" class="submit-btn"><i class="fas fa-save"></i> Save to Google Sheets</button></form></div>
      </div>
    </div>

    <!-- Overview Tab - Full charts -->
    <div id="overviewTab" class="tab-pane hidden"><div class="cards-grid" id="mainKPIs"></div><div class="dashboard-grid"><div class="chart-card"><h3>Income Distribution</h3><div class="chart-container"><canvas id="incomePieChart"></canvas></div></div><div class="chart-card"><h3>Monthly Income Trend</h3><div class="chart-container"><canvas id="monthlyIncomeTrendChart"></canvas></div></div><div class="chart-card"><h3>Income vs Expenses</h3><div class="chart-container"><canvas id="incomeExpenseCompareChart"></canvas></div></div><div class="chart-card"><h3>Top 5 Offering Types</h3><div class="chart-container"><canvas id="topCategoriesChart"></canvas></div></div></div><div class="dashboard-grid"><div class="chart-card"><h3>Monthly Burn Rate <span id="overallBurnRateBadge"></span></h3><div class="chart-container"><canvas id="burnRateChart"></canvas></div></div><div class="chart-card"><h3>Income vs Expense Trend</h3><div class="chart-container"><canvas id="monthlyTrendChart"></canvas></div></div></div></div>
    
    <!-- Offerings Tab -->
    <div id="offeringsTab" class="tab-pane hidden"><div class="cards-grid" id="offeringsKPIs"></div><div class="dashboard-grid"><div class="chart-card"><h3>Offerings by Type</h3><div class="chart-container"><canvas id="offeringsByTypeChart"></canvas></div></div><div class="chart-card"><h3>Offerings Monthly Trend</h3><div class="chart-container"><canvas id="offeringsTrendChart"></canvas></div></div><div class="chart-card"><h3>Offering Distribution</h3><div class="chart-container"><canvas id="offeringsPieChart"></canvas></div></div><div class="chart-card"><h3>Offerings Growth Rate <span id="offeringsGrowthBadge"></span></h3><div class="chart-container"><canvas id="offeringsGrowthChart"></canvas></div></div></div><div class="data-table"><h4><i class="fas fa-hand-holding-heart"></i> Individual Offerings History (Google Sheets)</h4><div id="offeringsTable"></div></div></div>
    
    <!-- Tithes Tab -->
    <div id="tithesTab" class="tab-pane hidden"><div class="cards-grid" id="tithesKPIs"></div><div class="dashboard-grid"><div class="chart-card"><h3>Tithes by Type</h3><div class="chart-container"><canvas id="tithesByTypeChart"></canvas></div></div><div class="chart-card"><h3>Tithes Monthly Trend</h3><div class="chart-container"><canvas id="tithesTrendChart"></canvas></div></div><div class="chart-card"><h3>Top Individual Tithers</h3><div class="chart-container"><canvas id="topTithersChart"></canvas></div></div><div class="chart-card"><h3>Tithes Growth Rate <span id="tithesGrowthBadge"></span></h3><div class="chart-container"><canvas id="tithesGrowthChart"></canvas></div></div><div class="chart-card"><h3>📊 Individual Tithing by Month</h3><div class="chart-container"><canvas id="individualTithingChart"></canvas></div><div class="filter-group" style="margin-top:15px;"><label><i class="fas fa-user"></i> Select Member</label><select id="memberSelectChart" class="form-select"></select></div></div></div><div class="data-table"><h4><i class="fas fa-users"></i> Individual Tithes Records</h4><div id="tithesTable"></div></div></div>
    
    <!-- Expenses Tab -->
    <div id="expensesTab" class="tab-pane hidden"><div class="cards-grid" id="expensesKPIs"></div><div class="dashboard-grid"><div class="chart-card"><h3>Expenses by Category</h3><div class="chart-container"><canvas id="expensesByCategoryChart"></canvas></div></div><div class="chart-card"><h3>Expenses Monthly Trend</h3><div class="chart-container"><canvas id="expensesTrendChart"></canvas></div></div><div class="chart-card"><h3>Top Expense Categories</h3><div class="chart-container"><canvas id="topExpensesChart"></canvas></div></div><div class="chart-card"><h3>Expenses Growth Rate <span id="expensesGrowthBadge"></span></h3><div class="chart-container"><canvas id="expensesGrowthChart"></canvas></div></div></div><div class="data-table"><h4><i class="fas fa-receipt"></i> Individual Expense Transactions</h4><div id="expensesTable"></div></div></div>
    
    <!-- Advanced Tab -->
    <div id="advancedTab" class="tab-pane hidden"><div class="cards-grid" id="advancedKPIs"></div><div class="dashboard-grid"><div class="chart-card"><h3>3-Month Moving Average</h3><div class="chart-container"><canvas id="movingAvgChart"></canvas></div></div><div class="chart-card"><h3>3-Month Forecast</h3><div class="chart-container"><canvas id="forecastChart"></canvas></div></div><div class="chart-card"><h3>Seasonality Analysis</h3><div class="chart-container"><canvas id="seasonalityChart"></canvas></div></div><div class="chart-card"><h3>Anomaly Detection</h3><div class="chart-container"><canvas id="anomalyChart"></canvas></div></div></div><div class="data-table"><h4><i class="fas fa-chart-line"></i> Advanced Metrics</h4><div id="advancedReportTable"></div></div></div>
  </div>
  <div class="toast" id="toast"></div>
</div>

<script>
  Chart.register(ChartDataLabels);
  Chart.defaults.set('plugins.datalabels', { color: '#1f2937', anchor: 'end', align: 'top', offset: 5, font: { size: 9, weight: 'bold' } });
  
  const GOOGLE_SHEETS_WEBHOOK = "https://script.google.com/macros/s/AKfycbySOV6jW9K-w0qACbmJZoklhjahZUPqTuRNYyo8-QwBGVNrkTjKodfDNMgyKN0FUNXG/exec";
  const VALID_USERNAME = "MPAC";
  const VALID_PASSWORD = "MPAC#2037";
  let financialData = { offerings: [], tithes: [], expenses: [] };
  let currentFilters = { year: "all", month: "all", category: "all", startDate: "", endDate: "" };
  let charts = {};
  let isSaving = false;
  
  function showToast(msg, isErr = false) { let t = document.getElementById("toast"); t.innerText = msg; t.style.display = "block"; setTimeout(() => t.style.display = "none", 3000); }
  function saveLocal() { localStorage.setItem('mpac_financial_backup', JSON.stringify(financialData)); }
  
  async function syncToGoogleSheets(type, record) {
    try { await fetch(GOOGLE_SHEETS_WEBHOOK, { method: 'POST', mode: 'no-cors', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'addRecord', type, record, timestamp: new Date().toISOString() }) }); return true; } catch(e) { console.warn(e); return false; }
  }
  
  async function pullFromGoogleSheets() {
    try {
      const response = await fetch(`${GOOGLE_SHEETS_WEBHOOK}?action=getData&t=${Date.now()}`);
      const data = await response.json();
      if (data.success) { financialData = { offerings: data.offerings || [], tithes: data.tithes || [], expenses: data.expenses || [] }; document.getElementById("syncStatus").innerHTML = "🟢 Synced with Google Sheets • " + new Date().toLocaleTimeString(); saveLocal(); return true; }
      throw new Error();
    } catch(e) {
      const saved = localStorage.getItem('mpac_financial_backup');
      if (saved) { financialData = JSON.parse(saved); document.getElementById("syncStatus").innerHTML = "⚠️ Offline Mode • Local Data"; return true; }
      loadDemoData();
      document.getElementById("syncStatus").innerHTML = "⚠️ Demo Mode • Using Sample Data";
      return false;
    }
  }
  
  async function addRecord(type, record, currentBtn) {
    if (isSaving) { showToast("Please wait, previous save in progress...", true); return false; }
    isSaving = true;
    if (currentBtn) { currentBtn.disabled = true; currentBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...'; }
    if (type === 'offering') financialData.offerings.unshift(record);
    else if (type === 'tithe') financialData.tithes.unshift(record);
    else if (type === 'expense') financialData.expenses.unshift(record);
    saveLocal();
    updateAllDashboards();
    await syncToGoogleSheets(type, record);
    showToast(`✅ ${type} saved + Google Sheets synced!`);
    if (currentBtn) { currentBtn.disabled = false; currentBtn.innerHTML = '<i class="fas fa-save"></i> Save to Google Sheets'; }
    isSaving = false;
    return true;
  }
  
  function loadDemoData() {
    financialData = {
      offerings: [{ type:"General Offering", amount:12500, date:"2026-03-27", month:"Mar", monthNum:3, year:2026, receivedBy:"John M." },{ type:"Thanksgiving", amount:3450, date:"2026-03-20", month:"Mar", monthNum:3, year:2026, receivedBy:"Sarah K." },{ type:"Building Fund", amount:8900, date:"2026-03-15", month:"Mar", monthNum:3, year:2026, receivedBy:"Michael T." },{ type:"First Fruits", amount:15600, date:"2026-03-05", month:"Mar", monthNum:3, year:2026, receivedBy:"Pastor David" },{ type:"General Offering", amount:10800, date:"2026-02-10", month:"Feb", monthNum:2, year:2026, receivedBy:"Lisa W." },{ type:"General Offering", amount:9500, date:"2026-01-15", month:"Jan", monthNum:1, year:2026, receivedBy:"Robert J." }],
      tithes: [{ type:"Regular Tithe (10%)", amount:28700, date:"2026-03-25", month:"Mar", monthNum:3, year:2026, memberName:"John Doe" },{ type:"Regular Tithe (10%)", amount:25400, date:"2026-02-22", month:"Feb", monthNum:2, year:2026, memberName:"Robert Johnson" },{ type:"Regular Tithe (10%)", amount:15200, date:"2026-03-18", month:"Mar", monthNum:3, year:2026, memberName:"Mary Williams" },{ type:"First Tithe", amount:5000, date:"2026-01-10", month:"Jan", monthNum:1, year:2026, memberName:"John Doe" }],
      expenses: [{ category:"Salaries", amount:18500, date:"2026-03-15", month:"Mar", monthNum:3, year:2026, description:"Staff Salaries" },{ category:"Utilities", amount:4200, date:"2026-03-20", month:"Mar", monthNum:3, year:2026, description:"Eskom Electricity" },{ category:"Programs", amount:6800, date:"2026-02-10", month:"Feb", monthNum:2, year:2026, description:"Youth Conference" }]
    };
    saveLocal();
  }
  
  function filterData() {
    let { year, month, category, startDate, endDate } = currentFilters;
    let off = financialData.offerings.filter(o => (year=="all"||o.year==year) && (month=="all"||o.monthNum==month));
    let tit = financialData.tithes.filter(t => (year=="all"||t.year==year) && (month=="all"||t.monthNum==month));
    let exp = financialData.expenses.filter(e => (year=="all"||e.year==year) && (month=="all"||e.monthNum==month));
    if(startDate && endDate) { let s=new Date(startDate), e=new Date(endDate); s.setHours(0,0,0,0); e.setHours(23,59,59,999); off=off.filter(o=>new Date(o.date)>=s&&new Date(o.date)<=e); tit=tit.filter(t=>new Date(t.date)>=s&&new Date(t.date)<=e); exp=exp.filter(e=>new Date(e.date)>=s&&new Date(e.date)<=e); }
    if(category==="offerings") return { offerings:off, tithes:[], expenses:[] };
    if(category==="tithes") return { offerings:[], tithes:tit, expenses:[] };
    if(category==="expenses") return { offerings:[], tithes:[], expenses:exp };
    return { offerings:off, tithes:tit, expenses:exp };
  }
  
  function getMonthlySeries(items) { const m=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']; return m.map((_,i)=>items.filter(x=>x.monthNum===i+1).reduce((s,x)=>s+x.amount,0)); }
  function growthRate(series) { return series.map((v,i)=>i===0||series[i-1]===0?0:((v-series[i-1])/series[i-1])*100); }
  function getBurnClass(p) { if(p<=70) return 'good'; if(p<=90) return 'warning'; return 'critical'; }
  
  function exportCompleteArchiveToExcel() {
    try {
      const offeringRows = financialData.offerings.map(o => ({ Date: o.date, Type: o.type, Amount_ZAR: o.amount, "Received By": o.receivedBy || "Anonymous", Month: o.month, Year: o.year }));
      const titheRows = financialData.tithes.map(t => ({ Date: t.date, "Member Name": t.memberName, "Tithe Type": t.type, Amount_ZAR: t.amount, Month: t.month, Year: t.year }));
      const expenseRows = financialData.expenses.map(e => ({ Date: e.date, Category: e.category, "Description": e.description || "-", Amount_ZAR: e.amount, Month: e.month, Year: e.year }));
      const totalOff = financialData.offerings.reduce((s,o)=>s+o.amount,0);
      const totalTit = financialData.tithes.reduce((s,t)=>s+t.amount,0);
      const totalExp = financialData.expenses.reduce((s,e)=>s+e.amount,0);
      const summaryRows = [{ Metric: "Total Offerings", Value_ZAR: totalOff },{ Metric: "Total Tithes", Value_ZAR: totalTit },{ Metric: "Total Income", Value_ZAR: totalOff+totalTit },{ Metric: "Total Expenses", Value_ZAR: totalExp },{ Metric: "Net Balance", Value_ZAR: (totalOff+totalTit)-totalExp },{ Metric: "Total Records", Value_ZAR: financialData.offerings.length+financialData.tithes.length+financialData.expenses.length }];
      const wb = XLSX.utils.book_new();
      XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(offeringRows), "Offerings");
      XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(titheRows), "Tithes");
      XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(expenseRows), "Expenses");
      XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(summaryRows), "Archive_Summary");
      XLSX.writeFile(wb, `MPAC_Complete_Archive_${new Date().toISOString().slice(0,19)}.xlsx`);
      showToast(`📀 Full archive exported: ${financialData.offerings.length+financialData.tithes.length+financialData.expenses.length} records`);
    } catch(e) { showToast("Export error", true); }
  }
  
  function updateAllDashboards() {
    const f = filterData();
    const totalOff = f.offerings.reduce((a,b)=>a+b.amount,0);
    const totalTit = f.tithes.reduce((a,b)=>a+b.amount,0);
    const totalExp = f.expenses.reduce((a,b)=>a+b.amount,0);
    const totalInc = totalOff+totalTit;
    const balance = totalInc-totalExp;
    document.getElementById("balanceAmount").innerHTML = `ZAR ${balance.toLocaleString()}`;
    const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    const offS = getMonthlySeries(f.offerings), titS = getMonthlySeries(f.tithes), expS = getMonthlySeries(f.expenses);
    const incS = months.map((_,i)=>offS[i]+titS[i]);
    const offG = growthRate(offS), titG = growthRate(titS), expG = growthRate(expS);
    const burnRates = months.map((_,i)=> incS[i]>0 ? (expS[i]/incS[i])*100 : 0);
    const overallBurn = totalInc>0 ? (totalExp/totalInc)*100 : 0;
    const burnClass = getBurnClass(overallBurn);
    document.getElementById("overallBurnRateBadge").innerHTML = `<span class="burn-rate-badge ${burnClass}">🔥 ${overallBurn.toFixed(1)}% spent</span>`;
    document.getElementById("mainKPIs").innerHTML = `<div class="stat-card"><div class="card-value">ZAR ${totalOff.toLocaleString()}</div><div>Offerings</div><div class="${offG[2]>0?'trend-up':'trend-down'}">${Math.abs(offG[2]).toFixed(1)}%</div></div><div class="stat-card"><div class="card-value">ZAR ${totalTit.toLocaleString()}</div><div>Tithes</div><div class="${titG[2]>0?'trend-up':'trend-down'}">${Math.abs(titG[2]).toFixed(1)}%</div></div><div class="stat-card"><div class="card-value">ZAR ${totalInc.toLocaleString()}</div><div>Income</div></div><div class="stat-card"><div class="card-value">ZAR ${totalExp.toLocaleString()}</div><div>Expenses</div></div>`;
    document.getElementById("offeringsKPIs").innerHTML = `<div class="stat-card"><div class="card-value">ZAR ${totalOff.toLocaleString()}</div><div>Individual Offerings</div></div>`;
    document.getElementById("tithesKPIs").innerHTML = `<div class="stat-card"><div class="card-value">ZAR ${totalTit.toLocaleString()}</div><div>Individual Tithes</div></div>`;
    document.getElementById("expensesKPIs").innerHTML = `<div class="stat-card"><div class="card-value">ZAR ${totalExp.toLocaleString()}</div><div>Individual Expenses</div></div>`;
    document.getElementById("advancedKPIs").innerHTML = `<div class="stat-card"><div class="card-value">ZAR ${balance.toLocaleString()}</div><div>Net Balance</div></div><div class="stat-card"><div class="card-value">${totalInc>0?((totalInc-totalExp)/totalInc*100).toFixed(1):0}%</div><div>Margin</div></div><div class="stat-card"><div class="card-value">${overallBurn.toFixed(1)}%</div><div>Burn Rate</div></div>`;
    
    const offeringTypes = f.offerings.reduce((a,o)=>{ a[o.type]=(a[o.type]||0)+o.amount; return a;},{});
    const titheTypes = f.tithes.reduce((a,t)=>{ a[t.type]=(a[t.type]||0)+t.amount; return a;},{});
    const expenseCats = f.expenses.reduce((a,e)=>{ a[e.category]=(a[e.category]||0)+e.amount; return a;},{});
    const top5 = Object.entries(offeringTypes).sort((a,b)=>b[1]-a[1]).slice(0,5);
    const titherTotals = f.tithes.reduce((a,t)=>{ a[t.memberName]=(a[t.memberName]||0)+t.amount; return a;},{});
    
    const updateChart = (id, cfg) => { if(charts[id]) charts[id].destroy(); const ctx = document.getElementById(id); if(ctx) charts[id] = new Chart(ctx, cfg); };
    updateChart("incomePieChart", { type:'doughnut', data:{ labels:['Offerings','Tithes'], datasets:[{ data:[totalOff,totalTit], backgroundColor:['#c62828','#0a2f44'] }] }, options:{ plugins:{ datalabels:{ formatter:(v)=>`ZAR ${v.toLocaleString()}`, anchor:'center', color:'white' } } } });
    updateChart("monthlyIncomeTrendChart", { type:'line', data:{ labels:months, datasets:[{ label:'Income', data:incS, borderColor:'#c62828', fill:true, tension:0.4 }] }, options:{ plugins:{ datalabels:{ display:false } } } });
    updateChart("incomeExpenseCompareChart", { type:'bar', data:{ labels:['Income','Expenses'], datasets:[{ label:'Amount', data:[totalInc,totalExp], backgroundColor:['#0a2f44','#c62828'] }] } });
    updateChart("topCategoriesChart", { type:'bar', data:{ labels:top5.map(c=>c[0]), datasets:[{ label:'Amount', data:top5.map(c=>c[1]), backgroundColor:'#c62828' }] } });
    updateChart("burnRateChart", { type:'line', data:{ labels:months, datasets:[{ label:'Burn Rate %', data:burnRates, borderColor:'#f59e0b', fill:true }] }, options:{ scales:{ y:{ min:0, max:150 } } } });
    updateChart("monthlyTrendChart", { type:'line', data:{ labels:months, datasets:[{ label:'Income', data:incS, borderColor:'#10b981' },{ label:'Expenses', data:expS, borderColor:'#ef4444' }] } });
    updateChart("offeringsByTypeChart", { type:'bar', data:{ labels:Object.keys(offeringTypes), datasets:[{ label:'Amount', data:Object.values(offeringTypes), backgroundColor:'#c62828' }] } });
    updateChart("offeringsTrendChart", { type:'line', data:{ labels:months, datasets:[{ label:'Offerings', data:offS, borderColor:'#c62828', fill:true }] } });
    updateChart("offeringsPieChart", { type:'pie', data:{ labels:Object.keys(offeringTypes), datasets:[{ data:Object.values(offeringTypes), backgroundColor:['#c62828','#e57373','#ef9a9a','#ffcdd2','#b71c1c'] }] }, options:{ plugins:{ datalabels:{ formatter:(v)=>`ZAR ${v.toLocaleString()}`, anchor:'center', color:'white' } } } });
    updateChart("offeringsGrowthChart", { type:'line', data:{ labels:months, datasets:[{ label:'Growth %', data:offG, borderColor:'#10b981' }] } });
    updateChart("tithesByTypeChart", { type:'pie', data:{ labels:Object.keys(titheTypes), datasets:[{ data:Object.values(titheTypes), backgroundColor:['#0a2f44','#1e4a6e'] }] }, options:{ plugins:{ datalabels:{ formatter:(v)=>`ZAR ${v.toLocaleString()}`, anchor:'center', color:'white' } } } });
    updateChart("tithesTrendChart", { type:'line', data:{ labels:months, datasets:[{ label:'Tithes', data:titS, borderColor:'#0a2f44', fill:true }] } });
    updateChart("topTithersChart", { type:'bar', data:{ labels:Object.keys(titherTotals).slice(0,5), datasets:[{ label:'Amount', data:Object.values(titherTotals).slice(0,5), backgroundColor:'#0a2f44' }] } });
    updateChart("tithesGrowthChart", { type:'line', data:{ labels:months, datasets:[{ label:'Growth %', data:titG, borderColor:'#0a2f44' }] } });
    updateChart("expensesByCategoryChart", { type:'pie', data:{ labels:Object.keys(expenseCats), datasets:[{ data:Object.values(expenseCats), backgroundColor:['#c62828','#e57373','#ef9a9a'] }] }, options:{ plugins:{ datalabels:{ formatter:(v)=>`ZAR ${v.toLocaleString()}`, anchor:'center', color:'white' } } } });
    updateChart("expensesTrendChart", { type:'line', data:{ labels:months, datasets:[{ label:'Expenses', data:expS, borderColor:'#c62828', fill:true }] } });
    updateChart("topExpensesChart", { type:'bar', data:{ labels:Object.keys(expenseCats), datasets:[{ label:'Amount', data:Object.values(expenseCats), backgroundColor:'#c62828' }] } });
    updateChart("expensesGrowthChart", { type:'line', data:{ labels:months, datasets:[{ label:'Growth %', data:expG, borderColor:'#c62828' }] } });
    
    const ma3 = incS.map((_,i)=> i<2 ? null : (incS[i]+incS[i-1]+incS[i-2])/3);
    updateChart("movingAvgChart", { type:'line', data:{ labels:months, datasets:[{ label:'Income', data:incS, borderColor:'#c62828' },{ label:'3-Month MA', data:ma3, borderColor:'#0a2f44', borderDash:[5,5] }] }, options:{ plugins:{ datalabels:{ display:false } } } });
    const forecast = incS.slice(-3).map(v=>v*1.09);
    updateChart("forecastChart", { type:'line', data:{ labels:[...months.slice(-3),'Apr','May','Jun'], datasets:[{ label:'Historical', data:[...incS.slice(-3),null,null,null], borderColor:'#c62828' },{ label:'Forecast', data:[...Array(3).fill(null),...forecast], borderColor:'#10b981', borderDash:[5,5] }] }, options:{ plugins:{ datalabels:{ display:false } } } });
    const avg = incS.filter(v=>v>0).reduce((a,b)=>a+b,0)/incS.filter(v=>v>0).length;
    const season = incS.map(v=>v/avg);
    updateChart("seasonalityChart", { type:'bar', data:{ labels:months, datasets:[{ label:'Seasonality Index', data:season, backgroundColor:'#c62828' }] } });
    const mean = incS.filter(v=>v>0).reduce((a,b)=>a+b,0)/incS.filter(v=>v>0).length;
    const std = Math.sqrt(incS.map(v=>Math.pow(v-mean,2)).reduce((a,b)=>a+b,0)/incS.length);
    const anomalies = incS.map(v=>Math.abs(v-mean)>1.5*std);
    updateChart("anomalyChart", { type:'bar', data:{ labels:months, datasets:[{ label:'Income', data:incS, backgroundColor:anomalies.map(a=>a?'#ef4444':'#c62828') }] } });
    
    const sortedOff = [...f.offerings].sort((a,b)=>new Date(b.date)-new Date(a.date));
    document.getElementById("offeringsTable").innerHTML = `<table><thead><tr><th>Date</th><th>Type</th><th>Amount</th><th>Individual Name</th></tr></thead><tbody>${sortedOff.map(o=>`<tr><td>${o.date}</td><td><span class="badge-epic">${o.type}</span></td><td class="amount-positive">ZAR ${o.amount.toLocaleString()}</td><td>${o.receivedBy || 'Anonymous'}</td></tr>`).join('')||'<tr><td colspan="4">No offerings</td></tr>'}</tbody></table>`;
    document.getElementById("tithesTable").innerHTML = `<table><thead><tr><th>Date</th><th>Individual Member</th><th>Type</th><th>Amount</th></tr></thead><tbody>${[...f.tithes].sort((a,b)=>new Date(b.date)-new Date(a.date)).map(t=>`<tr><td>${t.date}</td><td><strong>${t.memberName}</strong></td><td><span class="badge-epic badge-blue">${t.type}</span></td><td class="amount-positive">ZAR ${t.amount.toLocaleString()}</td></tr>`).join('')||'<tr><td colspan="4">No tithes</td></tr>'}</tbody></table>`;
    document.getElementById("expensesTable").innerHTML = `<table><thead><tr><th>Date</th><th>Category</th><th>Description/Vendor</th><th>Amount</th></tr></thead><tbody>${[...f.expenses].sort((a,b)=>new Date(b.date)-new Date(a.date)).map(e=>`<tr><td>${e.date}</td><td><span class="badge-epic badge-red">${e.category}</span></td><td>${e.description || '-'}</td><td class="amount-negative">ZAR ${e.amount.toLocaleString()}</td></tr>`).join('')||'<tr><td colspan="4">No expenses</td></tr>'}</tbody></table>`;
    document.getElementById("advancedReportTable").innerHTML = `<table><thead><tr><th>Metric</th><th>Value</th><th>Insight</th></tr></thead><tbody><tr><td>Net Balance</td><td class="${balance>=0?'amount-positive':'amount-negative'}">ZAR ${balance.toLocaleString()}</td><td>${balance>=0?'Positive':'Deficit'}</td></tr><tr><td>Profit Margin</td><td>${totalInc>0?((totalInc-totalExp)/totalInc*100).toFixed(1):0}%</td><td>${((totalInc-totalExp)/(totalInc||1)*100)>20?'Healthy':'Monitor'}</td></tr><tr><td>Burn Rate</td><td class="${burnClass==='good'?'amount-positive':burnClass==='warning'?'trend-up':'amount-negative'}">${overallBurn.toFixed(1)}%</td><td>${overallBurn<=70?'Controlled':overallBurn<=90?'High':'Critical'}</td></tr></tbody></table>`;
    
    const members = [...new Set(f.tithes.map(t=>t.memberName))];
    const memberSelect = document.getElementById('memberSelectChart');
    if(memberSelect) { const cur = memberSelect.value; memberSelect.innerHTML = '<option value="">-- Select Member --</option>'+members.map(m=>`<option value="${m}">${m}</option>`).join(''); if(members.includes(cur)) memberSelect.value = cur; }
    const selected = memberSelect?.value;
    if(selected && selected!=="") {
      const memTithes = f.tithes.filter(t=>t.memberName===selected);
      const monthlyMem = months.map(m=>memTithes.filter(t=>t.month===m).reduce((s,t)=>s+t.amount,0));
      updateChart("individualTithingChart", { type:'bar', data:{ labels:months, datasets:[{ label:`${selected} - Tithes`, data:monthlyMem, backgroundColor:'#0a2f44', borderRadius:8 }] }, options:{ responsive:true, plugins:{ datalabels:{ formatter:(v)=>v>0?`ZAR ${v.toLocaleString()}`:'' } }, scales:{ y:{ beginAtZero:true } } } });
    }
  }
  
  // Event listeners for forms, filters, tabs
  document.getElementById('saveOfferingBtn')?.addEventListener('click', async (e) => { e.preventDefault(); const btn=document.getElementById('saveOfferingBtn'); if(btn.disabled||isSaving) return; const amt=parseFloat(document.getElementById('offeringAmount').value); if(isNaN(amt)||amt<=0) return showToast("Valid amount",true); const d=document.getElementById('offeringDate').value; if(!d) return showToast("Date required",true); const date=new Date(d); await addRecord("offering",{ date:d, type:document.getElementById('offeringTypeSelect').value, amount:amt, receivedBy:document.getElementById('offeringReceivedBy').value||"Individual", month:date.toLocaleString('default',{month:'short'}), monthNum:date.getMonth()+1, year:date.getFullYear() }, btn); document.getElementById('offeringForm').reset(); document.getElementById('offeringDate').value=new Date().toISOString().slice(0,10); });
  document.getElementById('saveTitheBtn')?.addEventListener('click', async (e) => { e.preventDefault(); const btn=document.getElementById('saveTitheBtn'); if(btn.disabled||isSaving) return; const amt=parseFloat(document.getElementById('titheAmount').value); if(isNaN(amt)||amt<=0) return showToast("Valid amount",true); if(!document.getElementById('memberName').value) return showToast("Member name required",true); const d=document.getElementById('titheDate').value; if(!d) return; const date=new Date(d); await addRecord("tithe",{ date:d, memberName:document.getElementById('memberName').value, type:document.getElementById('titheTypeSelect').value, amount:amt, month:date.toLocaleString('default',{month:'short'}), monthNum:date.getMonth()+1, year:date.getFullYear() }, btn); document.getElementById('titheForm').reset(); document.getElementById('titheDate').value=new Date().toISOString().slice(0,10); });
  document.getElementById('saveExpenseBtn')?.addEventListener('click', async (e) => { e.preventDefault(); const btn=document.getElementById('saveExpenseBtn'); if(btn.disabled||isSaving) return; const amt=parseFloat(document.getElementById('expenseAmount').value); if(isNaN(amt)||amt<=0) return showToast("Valid amount",true); const d=document.getElementById('expenseDate').value; if(!d) return; const date=new Date(d); await addRecord("expense",{ date:d, category:document.getElementById('expenseCategorySelect').value, description:document.getElementById('expenseDescription').value||"Individual expense", amount:amt, month:date.toLocaleString('default',{month:'short'}), monthNum:date.getMonth()+1, year:date.getFullYear() }, btn); document.getElementById('expenseForm').reset(); document.getElementById('expenseDate').value=new Date().toISOString().slice(0,10); });
  function applyFilters() { currentFilters = { year: document.getElementById("yearFilter").value, month: document.getElementById("monthFilter").value, category: document.getElementById("categoryFilter").value, startDate: document.getElementById("startDateFilter").value, endDate: document.getElementById("endDateFilter").value }; updateAllDashboards(); showToast("Filters applied"); }
  function resetFilters() { document.getElementById("yearFilter").value = "all"; document.getElementById("monthFilter").value = "all"; document.getElementById("categoryFilter").value = "all"; document.getElementById("startDateFilter").value = ""; document.getElementById("endDateFilter").value = ""; applyFilters(); }
  document.getElementById("applyFilters").addEventListener("click", applyFilters);
  document.getElementById("resetFilters").addEventListener("click", resetFilters);
  document.querySelectorAll('.tab').forEach(tab => { tab.addEventListener('click', () => { document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active')); tab.classList.add('active'); document.querySelectorAll('.tab-pane').forEach(p=>p.classList.add('hidden')); document.getElementById(tab.dataset.tab+'Tab').classList.remove('hidden'); document.getElementById('filterBar').style.display = tab.dataset.tab === 'dataentry' ? 'none' : 'flex'; updateAllDashboards(); }); });
  document.querySelectorAll('.epic-card').forEach(card=>{ card.addEventListener('click',()=>{ document.querySelectorAll('.epic-card').forEach(c=>c.classList.remove('active')); card.classList.add('active'); const t=card.dataset.type; ['offering','tithe','expense'].forEach(x=>document.getElementById(`${x}FormContainer`).classList.add('hidden')); document.getElementById(`${t}FormContainer`).classList.remove('hidden'); }); });
  document.getElementById('memberSelectChart')?.addEventListener('change', () => updateAllDashboards());
  document.getElementById('exportMasterArchiveBtn').addEventListener('click', exportCompleteArchiveToExcel);
  
  document.getElementById('loginForm').addEventListener('submit', async (e) => { e.preventDefault(); if(document.getElementById('loginUsername').value.trim()===VALID_USERNAME && document.getElementById('loginPassword').value===VALID_PASSWORD) { document.getElementById('loginOverlay').style.display = 'none'; document.getElementById('dashboardWrapper').classList.add('visible'); await pullFromGoogleSheets(); ["offering","tithe","expense"].forEach(t=>document.getElementById(`${t}Date`).value = new Date().toISOString().slice(0,10)); document.getElementById('filterBar').style.display = 'none'; updateAllDashboards(); showToast("✅ Connected to Google Sheets • Full archive export ready"); } else { document.getElementById('loginError').style.display = 'flex'; setTimeout(()=>document.getElementById('loginError').style.display='none',2000); } });
</script>
</body>
